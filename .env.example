# Copy to `.env` in this directory and fill in values. Never commit `.env`.
# `demo-api` and local `python worker/main.py` load `.env` automatically (via python-dotenv).
#
# -----------------------------------------------------------------------------
# Kubernetes manifests (edit these when you change cluster-side settings)
# -----------------------------------------------------------------------------
# All under `k8s/` in this project:
#   k8s/namespace.yaml
#   k8s/temporal-connection.example.yaml  → copy to temporal-connection.yaml; sets Temporal host + API key secret ref
#   k8s/temporal-worker-deployment.example.yaml → copy to temporal-worker-deployment.yaml; worker + task queue + rollout
# The API key for the cluster lives in a Kubernetes Secret (see comments in temporal-connection.example.yaml), not in YAML literals.
#
# -----------------------------------------------------------------------------
# Keep .env in sync with manifests (same logical values)
# -----------------------------------------------------------------------------
# TEMPORAL_ADDRESS          ↔ TemporalConnection spec.hostPort (k8s/temporal-connection*.yaml)
# TEMPORAL_NAMESPACE        ↔ TemporalWorkerDeployment spec.workerOptions.temporalNamespace (k8s/temporal-worker-deployment*.yaml)
# TEMPORAL_TASK_QUEUE       ↔ worker pod env TEMPORAL_TASK_QUEUE in that same TWD manifest (template.spec.containers[].env)
# TEMPORAL_API_KEY          ↔ same secret value you put in the temporal-api-key Secret (used by Connection + worker pod)
# K8S_NAMESPACE             ↔ metadata.namespace on TemporalConnection and TemporalWorkerDeployment
# K8S_TWD_NAME              ↔ TemporalWorkerDeployment metadata.name (NOT the same thing as task queue unless you chose that on purpose)
# TEMPORAL_DEPLOYMENT_NAME  ↔ optional; worker pod env from controller — must match for PinnedDemo pin. Defaults to K8S_TWD_NAME when unset.
#
# If demo-api starts workflows on the wrong queue or reads the wrong TWD status, compare the variables above to your applied YAML.

# -----------------------------------------------------------------------------
# Temporal Cloud — API key auth often uses the regional gRPC endpoint (see Cloud UI); *.tmprl.cloud may not work with API keys.
# -----------------------------------------------------------------------------
TEMPORAL_ADDRESS=us-east-1.aws.api.temporal.io:7233
TEMPORAL_NAMESPACE=
TEMPORAL_API_KEY=

TEMPORAL_TASK_QUEUE=worker-controller-demo

# -----------------------------------------------------------------------------
# Kubernetes — demo-api uses kubeconfig to GET the TemporalWorkerDeployment status.
# -----------------------------------------------------------------------------
K8S_NAMESPACE=worker-controller-demo
K8S_TWD_NAME=worker-controller-demo
# TEMPORAL_DEPLOYMENT_NAME=worker-controller-demo

# -----------------------------------------------------------------------------
# API server (optional)
# -----------------------------------------------------------------------------
# API_HOST=127.0.0.1
# API_PORT=8765
# CORS_ORIGINS=http://localhost:5173

# -----------------------------------------------------------------------------
# Local worker only — `uv run python worker/main.py` outside Kubernetes.
# In-cluster workers get deployment name, build id, and Temporal address from the controller.
# -----------------------------------------------------------------------------
# TEMPORAL_DEPLOYMENT_NAME=
# TEMPORAL_WORKER_BUILD_ID=
# DEMO_WORKER_VERSION=a
